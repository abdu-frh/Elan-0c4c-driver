          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"current-knowledge\">Current Knowledge</h2>\n<span class=\"paragraph\">The devices is a complete arm mini computer with cpu and storage.<br>\nIt manages the enroll, verfication, storage and deletion of the fingerprint.</span>\n<span class=\"paragraph\">To communication, happens on the USB Protocol, from Computer to the Elan ARM M4.</span></span>"
          }
        }

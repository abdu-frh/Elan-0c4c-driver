      "code_hash": "7225bb95e102fec7131d8419fd521b0b",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h3 id=\"commands-on-usb-layer-happens-on-usb-addr\">Commands on USB Layer happens on USB Addr:<br></h3>\n<span class=\"paragraph\">CMD_REQ: 0x01<br>\nCMD_RESP: 0x81</span>\n<span class=\"paragraph\">Data/Config_Upload: 0x02<br>\nDATA_IMG_RESP: 0x82<br></span>\n<h3 id=\"commands-on-i2i-layer\">Commands on I2I Layer<br></h3>\n<span class=\"paragraph\">CMD_REQ: 0x40 + HEX_CMD</span>\n<ul>\n<li>Req_length</li>\n<li>Resp length<br></li>\n</ul>\n<h4 id=\"example-firmware-version-request\">Example firmware version request<br></h4>\n<span class=\"paragraph\">static const struct elanmoc_cmd fw_ver_cmd = {<br>\n  .cmd_header = {0x40, 0x19},<br>\n  .cmd_len = 2,<br>\n  .resp_len = 2,<br>\n}</span></span>"
          }
        }
